{
  "name": "reaction-standee",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "GITHUB_PAGES=true VITE_DEPLOY_TARGET=static npm run build",
    "desktop": "npm run build && electron electron/main.cjs",
    "desktop:dev": "electron electron/main.cjs --dev",
    "wk:record": "bash scripts/run-wk-record-preview.sh",
    "wk:record:perf": "bash scripts/run-wk-record-preview.sh \"http://127.0.0.1:5173/record?perf=1&camera=low&inferFps=30\"",
    "wk:install": "bash scripts/install-wk-record-preview.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
